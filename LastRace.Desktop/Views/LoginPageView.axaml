<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="LastRace.Desktop.Views.LoginPageView"
             xmlns:vm="using:LastRace.Desktop.ViewModels"
             x:DataType="vm:LoginPageViewModel">
    <StackPanel Width="200" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="Login"/>
        <TextBox  Text="{Binding Login}"/>
        <TextBlock Text="Password"/>
        <TextBox Text="{Binding Password}"/>
        <Button  Margin="0, 10, 0,0 " Width="200" Content="Enter"/>
    </StackPanel>
</UserControl>
